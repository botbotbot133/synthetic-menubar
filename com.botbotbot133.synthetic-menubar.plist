<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.botbotbot133.synthetic-menubar</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>VENV_PLACEHOLDER</string>
        <string>REPO_PLACEHOLDER/synthetic_menubar_app.py</string>
    </array>
    
    <key>RunAtLoad</key>
    <true/>
    
    <key>KeepAlive</key>
    <true/>
    
    <key>StandardOutPath</key>
    <string>/tmp/synthetic-menubar.log</string>
    
    <key>StandardErrorPath</key>
    <string>/tmp/synthetic-menubar.error.log</string>
    
    <key>WorkingDirectory</key>
    <string>REPO_PLACEHOLDER</string>
</dict>
</plist>
